# Required for AI summary
ANTHROPIC_API_KEY=sk-ant-...
# Optional — override the Claude model (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=

# Optional — unlocks OpenWeatherMap source (free tier at openweathermap.org)
OWM_API_KEY=

# Optional — unlocks Tomorrow.io source (free tier at tomorrow.io)
TOMORROW_API_KEY=

# Optional — unlocks Meteo.pl ICM source (api.meteo.pl)
METEOPL_API_KEY=
